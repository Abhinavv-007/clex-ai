NODE_ENV=development
PORT=4000
LOG_LEVEL=info

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clex
JWT_SECRET=change-this-before-production

ALLOWED_ORIGINS=https://clex.in,https://www.clex.in,https://api.clex.in,http://localhost:3000,http://localhost:5173
PROVIDER_TIMEOUT_MS=60000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
NVIDIA_API_KEY=

# Paste the full Firebase Admin service account JSON as a single line.
FIREBASE_SERVICE_ACCOUNT_JSON=
